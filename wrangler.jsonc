{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inspiredink-demos",
  "main": "./workers/demo-router.js",
  "compatibility_date": "2026-06-26",
  "routes": [
    {
      "pattern": "falcettis.inspiredink.space",
      "custom_domain": true
    }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "run_worker_first": true,
    "not_found_handling": "404-page"
  }
}
