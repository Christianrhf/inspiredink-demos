---
import { business, services, trustSignals, values, projects, gallery, marquee } from "./data";

const logo = "/images/rolfi/gonzalez-logo.webp";
const heroPhoto = "/images/rolfi/casa-blanca.webp";
const teamPhoto = "/images/rolfi/team.webp";
const locationImage = "/images/rolfi/location.webp";

const navLinks = [
  ["Projects", "Proyectos", "#work"],
  ["Services", "Servicios", "#services"],
  ["Proof", "Prueba", "#proof"],
  ["Contact", "Contacto", "#contact"],
];
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gonzalez LLC | Full Interior Remodeling in Connecticut</title>
    <meta
      name="description"
      content="Visual Phase 1 mockup for Gonzalez LLC, full interior remodeling contractor serving Connecticut. Real project photos, services, bilingual UI, and direct call CTA."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@88,500;88,700;100,600;100,800;112,800&family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="nav">
      <a class="nav-brand" href="#top" aria-label="Gonzalez LLC home">
        <img src={logo} alt="Gonzalez LLC logo" />
      </a>

      <nav class="nav-links" aria-label="Page navigation">
        {navLinks.map(([en, es, href]) => (
          <a href={href} data-en={en} data-es={es}>{en}</a>
        ))}
      </nav>

      <div class="nav-actions">
        <button class="ghost-control" type="button" data-lang-toggle aria-label="Switch language">ES</button>
        <button class="ghost-control" type="button" data-theme-toggle aria-label="Toggle color theme">Dark</button>
        <a class="nav-phone" href={business.phone.href}>{business.phone.display}</a>
      </div>
    </header>

    <main id="top">
      <section class="hero blueprint">
        <div class="container hero-grid">
          <div class="hero-copy">
            <p class="kicker">
              <span>{business.license}</span>
              <span data-en="Serving Connecticut State" data-es="Sirviendo Connecticut">Serving Connecticut State</span>
            </p>

            <img class="hero-logo" src={logo} alt="Gonzalez LLC full interior remodeling logo" fetchpriority="high" />

            <h1 data-en="Interior remodeling. Finished right." data-es="Remodelacion interior. Bien terminada.">
              Interior remodeling. Finished right.
            </h1>

            <p
              class="hero-lead"
              data-en="Remodeling, kitchens, bathrooms, drywall, flooring, carpentry, painting and repairs delivered with clear communication and visible quality."
              data-es="Remodelacion, cocinas, banos, drywall, pisos, carpinteria, pintura y reparaciones con comunicacion clara y calidad visible."
            >
              Remodeling, kitchens, bathrooms, drywall, flooring, carpentry, painting and repairs delivered with clear communication and visible quality.
            </p>

            <div class="hero-actions">
              <a class="btn btn-primary" href={business.phone.href}>
                <span data-en="Call for estimate" data-es="Llamar para estimado">Call for estimate</span>
                <strong>{business.phone.display}</strong>
              </a>
              <a class="btn btn-secondary" href="#work" data-en="See real work" data-es="Ver trabajos reales">See real work</a>
            </div>
          </div>

          <div class="hero-media" aria-label="Real exterior project photo">
            <figure class="hero-project">
              <img src={heroPhoto} alt="Completed exterior remodeling project by Gonzalez LLC" fetchpriority="high" />
              <figcaption>
                <span data-en="Real project photo" data-es="Foto real de proyecto">Real project photo</span>
                <strong data-en="Exterior finish work" data-es="Trabajo exterior terminado">Exterior finish work</strong>
              </figcaption>
            </figure>
            <article class="team-badge">
              <img src={teamPhoto} alt="Gonzalez LLC work team" />
              <div>
                <span data-en="Work team" data-es="Equipo de trabajo">Work team</span>
                <strong data-en="10+ years of experience" data-es="10+ anos de experiencia">10+ years of experience</strong>
              </div>
            </article>
          </div>
        </div>
      </section>

      <div class="marquee" aria-hidden="true">
        <div class="marquee-track">
          {[...marquee, ...marquee].map((item) => <span>{item}</span>)}
        </div>
      </div>

      <section class="trust-bar">
        <div class="container trust-grid">
          {trustSignals.map((item) => (
            <div class="trust-item reveal">
              <strong>{item.value}</strong>
              <span data-en={item.en} data-es={item.es}>{item.en}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="section split-section" id="proof">
        <div class="container split-grid">
          <div class="section-copy reveal">
            <p class="eyebrow" data-en="Current Identity" data-es="Identidad actual">Current Identity</p>
            <h2 data-en="Not a generic contractor. A blue-brand remodeling crew." data-es="No es un contratista generico. Es una marca azul de remodelacion.">
              Not a generic contractor. A blue-brand remodeling crew.
            </h2>
          </div>
          <div class="statement-card reveal">
            <p data-en={business.sloganEn} data-es={business.sloganEs}>{business.sloganEn}</p>
            <span>{business.name} · {business.license}</span>
          </div>
        </div>
      </section>

      <section class="section services-section" id="services">
        <div class="container">
          <div class="section-head reveal">
            <p class="eyebrow" data-en="Services" data-es="Servicios">Services</p>
            <h2 data-en="One contractor for the interior finish stack." data-es="Un contratista para todos los acabados interiores.">
              One contractor for the interior finish stack.
            </h2>
          </div>

          <ol class="service-grid">
            {services.map((service) => (
              <li class="service-card reveal">
                <span class="service-num">{service.num}</span>
                <h3 data-en={service.en} data-es={service.es}>{service.en}</h3>
                <p data-en={service.descEn} data-es={service.descEs}>{service.descEn}</p>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="section work-section" id="work">
        <div class="container">
          <div class="section-head reveal">
            <p class="eyebrow" data-en="Real Photos" data-es="Fotos reales">Real Photos</p>
            <h2 data-en="The current site already has the proof. This layout lets it sell." data-es="El sitio actual ya tiene la prueba. Este layout la hace vender.">
              The current site already has the proof. This layout lets it sell.
            </h2>
          </div>
        </div>

        <div class="project-grid">
          {projects.map((project) => (
            <article class="project-card reveal">
              <div class="project-images">
                <figure>
                  <img src={project.before} alt={`${project.titleEn} before`} loading="lazy" />
                  <figcaption data-en={project.typeEn.split(" / ")[0]} data-es={project.typeEs.split(" / ")[0]}>
                    {project.typeEn.split(" / ")[0]}
                  </figcaption>
                </figure>
                <figure>
                  <img src={project.after} alt={`${project.titleEn} after`} loading="lazy" />
                  <figcaption data-en={project.typeEn.split(" / ")[1]} data-es={project.typeEs.split(" / ")[1]}>
                    {project.typeEn.split(" / ")[1]}
                  </figcaption>
                </figure>
              </div>
              <div class="project-meta">
                <span data-en={project.typeEn} data-es={project.typeEs}>{project.typeEn}</span>
                <h3 data-en={project.titleEn} data-es={project.titleEs}>{project.titleEn}</h3>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="gallery-strip" aria-label="Additional project gallery">
        {gallery.map((item) => (
          <figure class="gallery-tile reveal">
            <img src={item.src} alt={item.altEn} loading="lazy" />
            <figcaption data-en={item.labelEn} data-es={item.labelEs}>{item.labelEn}</figcaption>
          </figure>
        ))}
      </section>

      <section class="section values-section">
        <div class="container values-grid">
          <div class="section-copy reveal">
            <p class="eyebrow" data-en="Values" data-es="Valores">Values</p>
            <h2 data-en="Clear promises, not filler copy." data-es="Promesas claras, no texto de relleno.">
              Clear promises, not filler copy.
            </h2>
          </div>
          <div class="values-list">
            {values.map(([en, es, descEn, descEs]) => (
              <article class="value-card reveal">
                <h3 data-en={en} data-es={es}>{en}</h3>
                <p data-en={descEn} data-es={descEs}>{descEn}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section contact-section blueprint-dark" id="contact">
        <div class="container contact-grid">
          <div class="contact-copy reveal">
            <p class="eyebrow eyebrow-light" data-en="Free Estimate" data-es="Estimado gratis">Free Estimate</p>
            <h2 data-en="Call Gonzalez LLC before the next interior project." data-es="Llama a Gonzalez LLC antes del proximo proyecto interior.">
              Call Gonzalez LLC before the next interior project.
            </h2>
            <p
              data-en="Phase 1 keeps conversion simple: phone, email, location. No backend, no fake form, no CMS."
              data-es="Fase 1 mantiene la conversion simple: telefono, email y ubicacion. Sin backend, sin formulario falso, sin CMS."
            >
              Phase 1 keeps conversion simple: phone, email, location. No backend, no fake form, no CMS.
            </p>
            <div class="contact-actions">
              <a class="btn btn-white" href={business.phone.href}>
                <span data-en="Call now" data-es="Llamar ahora">Call now</span>
                <strong>{business.phone.display}</strong>
              </a>
              <a class="btn btn-outline-white" href={business.emailHref}>{business.email}</a>
            </div>
          </div>
          <aside class="location-card reveal">
            <img src={locationImage} alt="Gonzalez LLC location on Google Maps" loading="lazy" />
            <div>
              <span data-en="Based in West Haven" data-es="Ubicados en West Haven">Based in West Haven</span>
              <strong>{business.location}</strong>
              <a href={business.mapsHref} target="_blank" rel="noreferrer" data-en="Open map" data-es="Abrir mapa">Open map</a>
            </div>
          </aside>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <img src={logo} alt="Gonzalez LLC logo" loading="lazy" />
        <div>
          <strong>{business.name}</strong>
          <span>{business.license} · {business.location}</span>
        </div>
        <nav>
          <a href={business.sourceUrl} target="_blank" rel="noreferrer" data-en="Current Site" data-es="Sitio actual">Current Site</a>
          <a href={business.phone.href}>{business.phone.display}</a>
        </nav>
      </div>
    </footer>

    <a class="sticky-cta" href={business.phone.href}>
      <span data-en="Call for estimate" data-es="Llamar para estimado">Call for estimate</span>
      <strong>{business.phone.display}</strong>
    </a>

    <script>
      const root = document.documentElement;
      const langButton = document.querySelector("[data-lang-toggle]");
      const themeButton = document.querySelector("[data-theme-toggle]");
      const translatable = [...document.querySelectorAll("[data-en][data-es]")];
      const stickyCta = document.querySelector(".sticky-cta");

      let lang = "en";
      let theme = "light";

      function setLang(nextLang) {
        lang = nextLang;
        root.lang = lang;
        translatable.forEach((node) => {
          node.innerHTML = node.getAttribute(`data-${lang}`) || "";
        });
        if (langButton) langButton.textContent = lang === "en" ? "ES" : "EN";
      }

      function setTheme(nextTheme) {
        theme = nextTheme;
        root.dataset.theme = theme;
        if (themeButton) themeButton.textContent = theme === "light" ? "Dark" : "Light";
      }

      function toggleStickyCta() {
        stickyCta?.classList.toggle("is-visible", window.scrollY > 320);
      }

      langButton?.addEventListener("click", () => setLang(lang === "en" ? "es" : "en"));
      themeButton?.addEventListener("click", () => setTheme(theme === "light" ? "dark" : "light"));
      window.addEventListener("scroll", toggleStickyCta, { passive: true });
      toggleStickyCta();

      const observer = new IntersectionObserver(
        (entries) => entries.forEach((entry) => entry.isIntersecting && entry.target.classList.add("is-visible")),
        { threshold: 0.12 }
      );

      document.querySelectorAll(".reveal").forEach((node) => observer.observe(node));
    </script>

    <style is:global>
      :root {
        --blue: #3b7cc3;
        --blue-2: #235fa7;
        --blue-3: #dcecff;
        --navy: #061b35;
        --navy-2: #0b2b52;
        --steel: #60758e;
        --paper: #f6f9fd;
        --paper-2: #eaf2fb;
        --white: #fbfdff;
        --line: rgba(20, 67, 119, 0.16);
        --ink: #0a203b;
        --muted: #5d7087;
        --shadow: 0 26px 70px rgba(7, 38, 78, 0.16);
        --font-display: "Archivo", "Arial Narrow", sans-serif;
        --font-body: "Manrope", system-ui, sans-serif;
        --nav-h: 82px;
      }

      [data-theme="dark"] {
        --paper: #061322;
        --paper-2: #0b213a;
        --white: #0c1c31;
        --ink: #f2f8ff;
        --muted: #a8c0d8;
        --line: rgba(202, 225, 255, 0.18);
        --shadow: 0 26px 80px rgba(0, 0, 0, 0.36);
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; min-width: 320px; }
      body {
        margin: 0;
        color: var(--ink);
        background: var(--paper);
        font-family: var(--font-body);
        line-height: 1.6;
        padding-bottom: 78px;
      }
      img { display: block; max-width: 100%; height: auto; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; }
      h1, h2, h3, p { margin: 0; }
      h1, h2, h3 {
        font-family: var(--font-display);
        font-stretch: 100%;
        line-height: 0.96;
        letter-spacing: 0;
      }
      h1 {
        max-width: 680px;
        color: var(--white);
        font-size: clamp(3.35rem, 6.4vw, 6.6rem);
        font-weight: 800;
        text-transform: uppercase;
      }
      h2 {
        max-width: 900px;
        color: var(--ink);
        font-size: clamp(2.35rem, 5vw, 5.3rem);
        font-weight: 800;
        text-transform: uppercase;
      }
      .container { width: min(100% - 2rem, 1240px); margin-inline: auto; }
      .section { padding-block: clamp(4.5rem, 8vw, 8rem); }

      .blueprint {
        background:
          linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px),
          radial-gradient(circle at 78% 16%, rgba(74, 154, 232, 0.28), transparent 36%),
          linear-gradient(135deg, var(--navy), var(--blue-2));
        background-size: 34px 34px, 34px 34px, auto, auto;
      }
      .blueprint-dark {
        background:
          linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px),
          linear-gradient(135deg, #071a31, #235fa7);
        background-size: 34px 34px, 34px 34px, auto;
      }

      .nav {
        position: fixed;
        inset: 0 0 auto;
        z-index: 50;
        height: var(--nav-h);
        display: grid;
        grid-template-columns: 190px 1fr auto;
        align-items: center;
        gap: 1rem;
        padding-inline: clamp(1rem, 4vw, 4rem);
        background: color-mix(in srgb, var(--paper) 86%, transparent);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(18px);
      }
      .nav-brand img {
        width: 156px;
        border-radius: 2px;
        box-shadow: 0 8px 28px rgba(22, 77, 143, 0.16);
      }
      .nav-links { display: flex; justify-content: center; gap: clamp(1rem, 2.4vw, 2.2rem); }
      .nav-links a,
      .ghost-control,
      .nav-phone {
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }
      .nav-links a { color: var(--muted); }
      .nav-links a:hover { color: var(--blue-2); }
      .nav-actions { display: flex; align-items: center; justify-content: flex-end; gap: 0.55rem; }
      .ghost-control {
        min-width: 54px;
        min-height: 42px;
        color: var(--ink);
        background: transparent;
        border: 1px solid var(--line);
        border-radius: 999px;
        cursor: pointer;
      }
      .nav-phone {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        color: var(--white);
        background: var(--blue);
        border-radius: 999px;
        padding: 0 1.1rem;
        box-shadow: 0 16px 36px rgba(59, 124, 195, 0.28);
      }

      .hero {
        min-height: 100svh;
        padding-top: var(--nav-h);
        color: var(--white);
        overflow: hidden;
      }
      .hero-grid {
        min-height: calc(100svh - var(--nav-h));
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(420px, 0.85fr);
        gap: clamp(2rem, 5vw, 5rem);
        align-items: center;
        padding-block: clamp(3rem, 7vw, 6rem);
      }
      .kicker,
      .eyebrow {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75rem;
        color: var(--blue);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        margin-bottom: 1rem;
      }
      .hero .kicker { color: #cce4ff; }
      .kicker::before,
      .eyebrow::before {
        content: "";
        width: 42px;
        height: 3px;
        background: currentColor;
      }
      .hero-logo {
        width: min(380px, 88vw);
        margin-bottom: 1.25rem;
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.22);
      }
      .hero-lead {
        max-width: 660px;
        margin-top: 1.2rem;
        color: rgba(251, 253, 255, 0.78);
        font-size: clamp(1rem, 1.35vw, 1.16rem);
      }
      .hero-actions,
      .contact-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 2rem;
      }
      .btn {
        min-height: 56px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 0.85rem 1.15rem;
        border: 1px solid transparent;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
      }
      .btn:hover { transform: translateY(-2px); }
      .btn-primary {
        color: var(--white);
        background: var(--blue);
        box-shadow: 0 18px 42px rgba(59, 124, 195, 0.28);
      }
      .btn-secondary {
        color: var(--white);
        border-color: rgba(251,253,255,0.34);
        background: rgba(251,253,255,0.08);
      }
      .btn-white { color: var(--navy); background: var(--white); }
      .btn-outline-white { color: var(--white); border-color: rgba(251,253,255,0.38); }

      .hero-media { position: relative; min-height: 640px; }
      .hero-project {
        position: absolute;
        inset: 0 0 56px 0;
        margin: 0;
        border: 1px solid rgba(251,253,255,0.18);
        box-shadow: var(--shadow);
        overflow: hidden;
      }
      .hero-project::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(0deg, rgba(5, 27, 53, 0.62), transparent 45%);
      }
      .hero-project img { width: 100%; height: 100%; object-fit: cover; }
      .hero-project figcaption {
        position: absolute;
        left: 1.25rem;
        right: 1.25rem;
        bottom: 1.25rem;
        z-index: 2;
        color: var(--white);
      }
      .hero-project figcaption span,
      .team-badge span,
      .project-meta span,
      .location-card span {
        display: block;
        color: #cce4ff;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.13em;
        text-transform: uppercase;
      }
      .hero-project figcaption strong {
        display: block;
        margin-top: 0.25rem;
        font-family: var(--font-display);
        font-size: 2rem;
        line-height: 0.98;
        text-transform: uppercase;
      }
      .team-badge {
        position: absolute;
        right: -18px;
        bottom: 0;
        width: min(360px, 76%);
        display: grid;
        grid-template-columns: 118px 1fr;
        gap: 1rem;
        align-items: center;
        color: var(--ink);
        background: var(--white);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        padding: 0.75rem;
      }
      .team-badge img { width: 118px; aspect-ratio: 1.2; object-fit: cover; }
      .team-badge span { color: var(--blue-2); }
      .team-badge strong {
        display: block;
        margin-top: 0.3rem;
        font-family: var(--font-display);
        font-size: 1.35rem;
        line-height: 1;
        text-transform: uppercase;
      }

      .marquee {
        overflow: hidden;
        background: var(--blue);
        border-block: 1px solid rgba(255,255,255,0.18);
      }
      .marquee-track {
        display: inline-flex;
        gap: 0;
        white-space: nowrap;
        animation: scroll 44s linear infinite;
      }
      .marquee span {
        color: var(--white);
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 0.78rem 1.25rem;
      }
      .marquee span::after { content: "/"; margin-left: 1.25rem; opacity: 0.55; }
      @keyframes scroll { to { transform: translateX(-50%); } }

      .trust-bar { padding-block: 1.25rem; background: var(--paper-2); border-bottom: 1px solid var(--line); }
      .trust-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
      }
      .trust-item { background: var(--white); padding: clamp(1.25rem, 3vw, 2rem); }
      .trust-item strong {
        display: block;
        color: var(--blue);
        font-family: var(--font-display);
        font-size: clamp(2.4rem, 5vw, 4rem);
        line-height: 0.9;
      }
      .trust-item span {
        display: block;
        margin-top: 0.7rem;
        color: var(--muted);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .split-grid,
      .values-grid,
      .contact-grid {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: clamp(2rem, 6vw, 6rem);
        align-items: start;
      }
      .statement-card {
        color: var(--white);
        background: linear-gradient(135deg, var(--blue-2), var(--blue));
        box-shadow: var(--shadow);
        padding: clamp(1.6rem, 4vw, 3rem);
      }
      .statement-card p {
        font-family: var(--font-display);
        font-size: clamp(2rem, 4vw, 4rem);
        font-weight: 800;
        line-height: 0.98;
        text-transform: uppercase;
      }
      .statement-card span {
        display: block;
        margin-top: 1.5rem;
        color: rgba(251,253,255,0.78);
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .section-head { margin-bottom: clamp(2rem, 5vw, 4rem); }

      .services-section { background: var(--white); }
      .service-grid {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        margin: 0;
        padding: 0;
        background: var(--line);
        border: 1px solid var(--line);
      }
      .service-card {
        min-height: 270px;
        background: var(--paper);
        padding: clamp(1.35rem, 3vw, 2rem);
      }
      .service-num {
        color: var(--blue);
        font-weight: 800;
        letter-spacing: 0.14em;
      }
      .service-card h3 {
        margin-top: 2rem;
        color: var(--ink);
        font-size: clamp(1.55rem, 2.4vw, 2.25rem);
        text-transform: uppercase;
      }
      .service-card p,
      .value-card p,
      .contact-copy p {
        margin-top: 0.85rem;
        color: var(--muted);
      }

      .project-grid {
        width: min(100% - 2rem, 1440px);
        margin-inline: auto;
        display: grid;
        grid-template-columns: repeat(3, minmax(300px, 1fr));
        gap: 1rem;
      }
      .project-card {
        background: var(--white);
        border: 1px solid var(--line);
        box-shadow: 0 18px 54px rgba(7, 38, 78, 0.08);
      }
      .project-images { display: grid; grid-template-columns: repeat(2, 1fr); min-height: 420px; }
      .project-images figure {
        position: relative;
        margin: 0;
        overflow: hidden;
        background: var(--paper-2);
      }
      .project-images img { width: 100%; height: 100%; object-fit: cover; }
      .project-images figcaption {
        position: absolute;
        left: 0.75rem;
        bottom: 0.75rem;
        color: var(--white);
        background: rgba(6, 27, 53, 0.78);
        padding: 0.38rem 0.58rem;
        font-size: 0.67rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .project-meta { padding: 1.2rem; }
      .project-meta span { color: var(--blue-2); }
      .project-meta h3 {
        margin-top: 0.38rem;
        font-size: 1.65rem;
        text-transform: uppercase;
      }

      .gallery-strip {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr 1fr 1fr;
        grid-auto-rows: 260px;
        gap: 0.8rem;
        width: min(100% - 2rem, 1440px);
        margin: 0 auto clamp(4.5rem, 8vw, 8rem);
      }
      .gallery-tile {
        position: relative;
        margin: 0;
        overflow: hidden;
        background: var(--paper-2);
        border: 1px solid var(--line);
      }
      .gallery-tile:first-child { grid-row: span 2; }
      .gallery-tile:nth-child(2) { grid-column: span 2; }
      .gallery-tile img { width: 100%; height: 100%; object-fit: cover; }
      .gallery-tile figcaption {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: var(--white);
        background: rgba(6, 27, 53, 0.72);
        padding: 0.42rem 0.7rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .values-section { background: var(--paper-2); }
      .values-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
      }
      .value-card { min-height: 215px; background: var(--white); padding: clamp(1.35rem, 3vw, 2rem); }
      .value-card h3 { color: var(--blue-2); font-size: 1.8rem; text-transform: uppercase; }

      .contact-section { color: var(--white); }
      .contact-section h2 { color: var(--white); }
      .eyebrow-light { color: #cce4ff; }
      .contact-copy p { color: rgba(251,253,255,0.75); max-width: 620px; }
      .location-card {
        background: var(--white);
        color: var(--ink);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        padding: 0.8rem;
      }
      .location-card img { width: 100%; aspect-ratio: 1 / 0.78; object-fit: cover; }
      .location-card div { padding: 1rem 0.35rem 0.35rem; }
      .location-card span { color: var(--blue-2); }
      .location-card strong {
        display: block;
        margin-top: 0.45rem;
        font-family: var(--font-display);
        font-size: 1.55rem;
        line-height: 1;
        text-transform: uppercase;
      }
      .location-card a {
        display: inline-block;
        margin-top: 0.9rem;
        color: var(--blue-2);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .footer {
        color: rgba(251,253,255,0.76);
        background: var(--navy);
        padding-block: 2rem;
      }
      .footer-inner {
        display: grid;
        grid-template-columns: 130px 1fr auto;
        gap: 1.25rem;
        align-items: center;
      }
      .footer img { width: 130px; }
      .footer strong { display: block; color: var(--white); }
      .footer span { display: block; margin-top: 0.25rem; font-size: 0.84rem; }
      .footer nav { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.09em; }

      .sticky-cta {
        position: fixed;
        right: 1rem;
        bottom: 1rem;
        z-index: 60;
        width: min(calc(100% - 2rem), 365px);
        min-height: 58px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        color: var(--white);
        background: var(--blue);
        border: 1px solid rgba(255,255,255,0.24);
        box-shadow: 0 24px 60px rgba(7, 38, 78, 0.28);
        padding: 0.85rem 1rem;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        opacity: 0;
        pointer-events: none;
        transform: translateY(14px);
        transition: opacity 0.22s ease, transform 0.22s ease;
      }
      .sticky-cta.is-visible { opacity: 1; pointer-events: auto; transform: none; }

      .reveal {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 0.65s ease, transform 0.65s ease;
      }
      .reveal.is-visible { opacity: 1; transform: none; }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .marquee-track { animation: none; }
        .reveal, .sticky-cta { transition: none; }
      }

      @media (max-width: 1060px) {
        .nav { grid-template-columns: 170px 1fr auto; }
        .nav-links { display: none; }
        .hero-grid,
        .split-grid,
        .values-grid,
        .contact-grid { grid-template-columns: 1fr; }
        .hero-media { min-height: 520px; }
        .service-grid { grid-template-columns: repeat(2, 1fr); }
        .project-grid { grid-template-columns: 1fr; }
        .gallery-strip { grid-template-columns: repeat(2, 1fr); }
        .gallery-tile:first-child,
        .gallery-tile:nth-child(2) { grid-column: auto; grid-row: auto; }
      }

      @media (max-width: 720px) {
        :root { --nav-h: 72px; }
        body { padding-bottom: 74px; }
        .container { width: min(100% - 1.25rem, 1240px); }
        .nav {
          grid-template-columns: 116px 1fr;
          padding-inline: 0.65rem;
        }
        .nav-brand img { width: 106px; }
        .nav-actions { gap: 0.4rem; }
        .ghost-control { min-width: 46px; min-height: 40px; font-size: 0.7rem; }
        .nav-phone { display: none; }
        .hero-grid { min-height: auto; padding-block: 2.5rem 3rem; }
        .hero-logo { width: min(300px, 100%); }
        h1 { font-size: clamp(1.95rem, 8.25vw, 2.65rem); }
        h2 { font-size: clamp(2.15rem, 10vw, 3.7rem); }
        .kicker, .eyebrow { font-size: 0.68rem; gap: 0.55rem; }
        .hero-actions, .contact-actions { display: grid; }
        .btn {
          width: 100%;
          min-height: 54px;
          display: grid;
          justify-items: start;
          gap: 0.5rem;
          padding-inline: 0.85rem;
          font-size: 0.68rem;
        }
        .btn strong { font-size: 0.8rem; letter-spacing: 0.04em; }
        .hero-media { min-height: 460px; }
        .hero-project { inset: 0 0 88px 0; }
        .team-badge {
          right: 0;
          width: 100%;
          grid-template-columns: 94px 1fr;
        }
        .team-badge img { width: 94px; }
        .trust-grid,
        .service-grid,
        .values-list,
        .gallery-strip { grid-template-columns: 1fr; }
        .project-images { min-height: 315px; }
        .footer-inner {
          grid-template-columns: 1fr;
          align-items: start;
        }
        .sticky-cta {
          left: 50%;
          right: auto;
          bottom: 0.75rem;
          width: calc(100% - 1rem);
          transform: translate(-50%, 14px);
        }
        .sticky-cta.is-visible { transform: translateX(-50%); }
        .sticky-cta span { display: none; }
      }
    </style>
  </body>
</html>
