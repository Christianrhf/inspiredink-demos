---
// Irish Home Improvement LLC — Bridgeport, CT
// Fase 1 · Maqueta visual · InspiredInk
// Design: Fraunces (editorial italic serif) + DM Sans. Irlandés · Familiar · Orgulloso.
// [NOTE: Replace photo-placeholder divs with real client project photos before sending]

import { phone, address, addressLink, mapEmbed, since, owner, rating, reviewCount, services, reviews, processSteps, areas } from "./data";

const navLinks = [
  ["Services", "Servicios", "#services"],
  ["About",    "Nosotros",  "#about"],
  ["Process",  "Proceso",   "#process"],
  ["Reviews",  "Reseñas",   "#reviews"],
  ["Contact",  "Contacto",  "#estimate"],
];

const marqueeItems = [
  "Deck Building", "Deck Repair", "Railing Systems",
  "Exterior Painting", "Interior Painting", "Home Improvements",
  "Construcción de Decks", "Reparación de Decks", "Barandas",
  "Pintura Exterior", "Pintura Interior", "Mejoras del Hogar",
];
---

<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Irish Home Improvement LLC | Decks, Painting & Home Improvements — Bridgeport, CT</title>
  <meta name="description" content="5-star rated home improvement contractor in Bridgeport, CT. Deck building, repair, railings, interior and exterior painting. Serving Fairfield County. Free estimates." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ── NAV ── -->
<header class="nav" id="nav">
  <a class="nav-brand" href="#top" aria-label="Irish Home Improvement Home">
    <span class="brand-i">Irish</span><span class="brand-r"> Home Improvement</span>
  </a>
  <nav class="nav-links" aria-label="Page sections">
    {navLinks.map(([en, es, href]) => (
      <a href={href} data-en={en} data-es={es}>{en}</a>
    ))}
  </nav>
  <div class="nav-right">
    <button class="ctrl" type="button" data-lang-toggle aria-label="Switch language">ES</button>
    <button class="ctrl" type="button" data-theme-toggle aria-label="Toggle theme">◐</button>
    <a class="nav-cta" href={phone.href}>{phone.display}</a>
  </div>
</header>

<main id="top">

<!-- ── HERO ── -->
<section class="hero">
  <div class="container hero-body reveal">
    <p class="hero-kicker">
      <span data-en={`Bridgeport, CT`} data-es="Bridgeport, CT">Bridgeport, CT</span>
      <span class="kik-sep" aria-hidden="true">·</span>
      <span data-en={`Est. ${since}`} data-es={`Est. ${since}`}>Est. {since}</span>
      <span class="kik-sep" aria-hidden="true">·</span>
      <span data-en="Licensed &amp; Insured" data-es="Licencia y Seguro">Licensed &amp; Insured</span>
      <span class="kik-rating" aria-label={`${rating} stars`}>★ {rating}</span>
    </p>

    <h1 class="hero-h1">
      <em class="hero-name" data-en="Irish" data-es="Irish">Irish</em>
      <span class="hero-trade" data-en="Home Improvement." data-es="Home Improvement.">Home<br/>Improvement.</span>
    </h1>

    <p class="hero-sub" data-en={`Decks built right. Railings that hold. Paint that lasts. Serving Fairfield County homeowners with honest craftsmanship. Call ${owner} for a free estimate.`} data-es={`Decks construidos bien. Barandas que aguantan. Pintura que dura. Sirviendo propietarios del Condado Fairfield con artesanía honesta. Llama a ${owner} para un estimado gratis.`}>
      Decks built right. Railings that hold. Paint that lasts. Serving Fairfield County homeowners with honest craftsmanship. Call {owner} for a free estimate.
    </p>

    <div class="hero-actions">
      <a class="btn-primary" href="#estimate" data-en="Free Estimate" data-es="Estimado Gratis">Free Estimate</a>
      <a class="btn-call" href={phone.href}>
        <span class="btn-call-label" data-en="Call Now" data-es="Llamar Ahora">Call Now</span>
        <strong>{phone.display}</strong>
      </a>
    </div>
  </div>

  <footer class="hero-foot">
    <div class="container hero-foot-inner">
      <span data-en="★ 5.0 on Google" data-es="★ 5.0 en Google">★ 5.0 on Google</span>
      <span class="hf-sep" aria-hidden="true">·</span>
      <span data-en="Licensed & Insured" data-es="Con Licencia y Seguro">Licensed &amp; Insured</span>
      <span class="hf-sep" aria-hidden="true">·</span>
      <span data-en="Free Estimates" data-es="Estimados Gratis">Free Estimates</span>
      <span class="hf-sep" aria-hidden="true">·</span>
      <span data-en="Mon–Sat 8:30 am – 5 pm" data-es="Lun–Sáb 8:30 am – 5 pm">Mon–Sat 8:30 am – 5 pm</span>
    </div>
  </footer>
</section>

<!-- ── MARQUEE ── -->
<div class="marquee-belt" aria-hidden="true">
  <div class="marquee-track">
    <span class="marquee-inner">
      {[...marqueeItems, ...marqueeItems].map(item => (
        <span class="marquee-item">{item}<span class="marquee-dot"> ·</span></span>
      ))}
    </span>
  </div>
</div>

<!-- ── SERVICES ── -->
<section class="section" id="services">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow" data-en="What We Do" data-es="Lo Que Hacemos">What We Do</p>
      <h2 data-en="Six trades. One reliable crew." data-es="Seis servicios. Un equipo confiable.">
        Six trades.<br/><em>One reliable crew.</em>
      </h2>
      <p class="section-lead reveal" data-en="From building a new deck to fixing what's broken to painting it clean. Irish Home Improvement handles the full range of home improvement work across Bridgeport and Fairfield County." data-es="Desde construir un deck nuevo hasta reparar lo que está roto o pintarlo limpio. Irish Home Improvement maneja todo tipo de mejoras del hogar en Bridgeport y el Condado Fairfield.">
        From building a new deck to fixing what's broken to painting it clean. Irish Home Improvement handles the full range of home improvement work across Bridgeport and Fairfield County.
      </p>
    </div>

    <ul class="svc-list">
      {services.map((s, i) => (
        <li class={`svc-row reveal${i > 0 && i < 3 ? ' delay-1' : i >= 3 ? ' delay-2' : ''}`}>
          <span class="svc-n">{s.num}</span>
          <h3 class="svc-h" data-en={s.en} data-es={s.es}>{s.en}</h3>
          <p class="svc-p" data-en={s.descEn} data-es={s.descEs}>{s.descEn}</p>
        </li>
      ))}
    </ul>

    <div class="svc-cta reveal" style="text-align:center; margin-top:3rem;">
      <a class="btn-outline" href="#estimate" data-en="Get a Free Estimate →" data-es="Pedir un Estimado Gratis →">Get a Free Estimate →</a>
    </div>
  </div>
</section>

<!-- ── ABOUT ── -->
<section class="section section-dark" id="about">
  <div class="container about-grid">
    <div class="about-copy reveal">
      <p class="eyebrow eyebrow-amber" data-en="Who We Are" data-es="Quiénes Somos">Who We Are</p>
      <h2 class="light" data-en={`Owned by ${owner}. Built on honest work.`} data-es={`Propiedad de ${owner}. Construido sobre trabajo honesto.`}>
        Owned by {owner}.<br/><em>Built on honest work.</em>
      </h2>
      <p data-en="Irish Home Improvement LLC is a Bridgeport-based contractor that's been serving Fairfield County homeowners with the kind of craftsmanship that earns repeat customers and five-star reviews." data-es="Irish Home Improvement LLC es un contratista con base en Bridgeport que ha servido a propietarios del Condado Fairfield con el tipo de artesanía que gana clientes recurrentes y reseñas de cinco estrellas.">
        Irish Home Improvement LLC is a Bridgeport-based contractor that's been serving Fairfield County homeowners with the kind of craftsmanship that earns repeat customers and five-star reviews.
      </p>
      <p data-en="We build decks that hold up to Connecticut winters, repair what other contractors won't touch, and paint clean the first time. Every project gets the same care, whether it's a small ramp repair or a full custom deck build." data-es="Construimos decks que aguantan los inviernos de Connecticut, reparamos lo que otros contratistas no tocan y pintamos limpio desde la primera vez. Cada proyecto recibe el mismo cuidado.">
        We build decks that hold up to Connecticut winters, repair what other contractors won't touch, and paint clean the first time. Every project gets the same care, whether it's a small ramp repair or a full custom deck build.
      </p>
      <div class="about-stats">
        <div class="about-stat">
          <strong>{rating}</strong>
          <span data-en="Stars on Google" data-es="Estrellas en Google">Stars on Google</span>
        </div>
        <div class="about-stat">
          <strong>10+</strong>
          <span data-en="Years in CT" data-es="Años en CT">Years in CT</span>
        </div>
        <div class="about-stat">
          <strong>100%</strong>
          <span data-en="Satisfaction" data-es="Satisfacción">Satisfaction</span>
        </div>
      </div>
    </div>

    <div class="about-visual reveal delay-1">
      {/* [NOTE: Replace with real project photo — deck or exterior painting] */}
      <div class="photo-frame">
        <div class="photo-inner">
          <div class="photo-tag" data-en="Custom Deck · Bridgeport, CT" data-es="Deck Custom · Bridgeport, CT">
            Custom Deck · Bridgeport, CT
          </div>
        </div>
      </div>
      <div class="owner-card">
        <div class="owner-avatar">{owner[0]}</div>
        <div class="owner-info">
          <strong>{owner}</strong>
          <span data-en="Owner, Irish Home Improvement LLC" data-es="Dueño, Irish Home Improvement LLC">
            Owner, Irish Home Improvement LLC
          </span>
          <a href={phone.href} class="owner-phone">{phone.display}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── PROCESS ── -->
<section class="section section-alt" id="process">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow" data-en="How We Work" data-es="Cómo Trabajamos">How We Work</p>
      <h2 data-en="From first call to finished project." data-es="Del primer llamado al proyecto terminado.">
        From first call<br/>to <em>finished project.</em>
      </h2>
    </div>
    <ol class="proc-list">
      {processSteps.map(([num, en, es, descEn, descEs], i) => (
        <li class={`proc-row reveal${i > 0 ? ` delay-${Math.min(i, 2)}` : ''}`}>
          <span class="proc-n">{num}</span>
          <div class="proc-body">
            <h3 class="proc-h" data-en={en} data-es={es}>{en}</h3>
            <p class="proc-p" data-en={descEn} data-es={descEs}>{descEn}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ── REVIEWS ── -->
<section class="section" id="reviews">
  <div class="container">
    <div class="section-head-c reveal">
      <p class="eyebrow eyebrow-c" data-en="What Clients Say" data-es="Lo Que Dicen los Clientes">
        What Clients Say
      </p>
      <h2 data-en="Real homeowners. Real results." data-es="Propietarios reales. Resultados reales.">
        Real homeowners.<br/><em>Real results.</em>
      </h2>
    </div>

    {/* Featured review — large and prominent */}
    <figure class="review-featured reveal">
      <div class="review-stars-lg">★★★★★</div>
      <blockquote>
        <p data-en={`"${reviews[0].quoteEn}"`} data-es={`"${reviews[0].quoteEs}"`}>
          "{reviews[0].quoteEn}"
        </p>
      </blockquote>
      <figcaption>
        <strong>{reviews[0].name}</strong>
        <span>{reviews[0].location}</span>
        <span class="review-via">via Google</span>
      </figcaption>
    </figure>

    {/* Supporting reviews */}
    <div class="review-sub-grid">
      {reviews.slice(1).map((r, i) => (
        <figure class={`review-sub reveal delay-${i + 1}`}>
          <div class="review-stars-sm">★★★★★</div>
          <blockquote>
            <p data-en={`"${r.quoteEn}"`} data-es={`"${r.quoteEs}"`}>"{r.quoteEn}"</p>
          </blockquote>
          <figcaption>
            <strong>{r.name}</strong>
            <span>{r.location}</span>
            <span class="review-via">via Google</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="review-tally reveal" data-en={`★ ${rating} rating across ${reviewCount} Google reviews`} data-es={`★ Calificación ${rating} en ${reviewCount} reseñas de Google`}>
      ★ {rating} rating across {reviewCount} Google reviews
    </p>
  </div>
</section>

<!-- ── SERVICE AREA ── -->
<section class="section section-brand" id="area">
  <div class="container area-layout">
    <div class="area-copy reveal">
      <p class="eyebrow eyebrow-amber" data-en="Service Area" data-es="Área de Servicio">Service Area</p>
      <h2 class="light" data-en="Bridgeport and all of Fairfield County." data-es="Bridgeport y todo el Condado Fairfield.">
        Bridgeport and all of<br/><em>Fairfield County.</em>
      </h2>
      <p style="color:rgba(255,255,255,.7); font-size:.97rem; line-height:1.7;"
        data-en="Based in Bridgeport, CT. We travel throughout Fairfield County for deck projects, painting jobs, and home improvements. Call to confirm availability in your town."
        data-es="Con base en Bridgeport, CT. Viajamos por todo el Condado Fairfield para proyectos de decks, pintura y mejoras del hogar. Llama para confirmar disponibilidad en tu pueblo.">
        Based in Bridgeport, CT. We travel throughout Fairfield County for deck projects, painting jobs, and home improvements. Call to confirm availability in your town.
      </p>
      <address class="area-addr">
        <a href={addressLink} target="_blank" rel="noreferrer">{address}</a>
      </address>
      <a class="btn-amber-lg" href={phone.href}>
        <span data-en="Call for Availability" data-es="Llamar para Disponibilidad">Call for Availability</span>
        <strong>{phone.display}</strong>
      </a>
    </div>
    <div class="area-right reveal delay-1">
      <p class="towns-label" data-en="Towns we serve:" data-es="Ciudades que servimos:">Towns we serve:</p>
      <div class="towns-grid">
        {areas.map(town => <span class="town-pill">{town}</span>)}
        <span class="town-pill more-pill" data-en="+ more" data-es="+ más">+ more</span>
      </div>
    </div>
  </div>
</section>

<!-- ── MAP ── -->
<div class="map-frame">
  <iframe
    src={mapEmbed}
    title="Irish Home Improvement LLC — 620 Clinton Ave, Bridgeport, CT"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</div>

<!-- ── ESTIMATE ── -->
<section class="section" id="estimate">
  <div class="container cta-layout">
    <div class="cta-copy reveal">
      <p class="eyebrow" data-en="Free Estimate" data-es="Estimado Gratis">Free Estimate</p>
      <h2 data-en="Ready to start your project?" data-es="¿Listo para empezar tu proyecto?">
        Ready to start<br/>your <em>project?</em>
      </h2>
      <p class="cta-lead" data-en={`Call ${owner} directly or fill out the form. We'll schedule a visit, review the scope, and give you a written estimate. No charge, no pressure.`} data-es={`Llama a ${owner} directamente o llena el formulario. Programaremos una visita, revisaremos el alcance y te daremos un estimado escrito. Sin costo, sin presión.`}>
        Call {owner} directly or fill out the form. We'll schedule a visit, review the scope, and give you a written estimate. No charge, no pressure.
      </p>
      <a class="cta-phone-link" href={phone.href}>
        <span data-en="Call for a free estimate" data-es="Llama para un estimado gratis">Call for a free estimate</span>
        <strong>{phone.display}</strong>
      </a>
      <address class="cta-addr">{address}</address>
      <p class="cta-hours" data-en="Monday – Saturday · 8:30 am – 5:00 pm" data-es="Lunes – Sábado · 8:30 am – 5:00 pm">
        Monday – Saturday · 8:30 am – 5:00 pm
      </p>
    </div>

    <form class="cta-form reveal delay-1" aria-label="Free estimate request form (decorative)">
      <h3 data-en="Tell us about your project" data-es="Cuéntanos tu proyecto">Tell us about your project</h3>
      <div class="form-row">
        <label>
          <span data-en="Name" data-es="Nombre">Name</span>
          <input type="text" placeholder="Your name" data-placeholder-en="Your name" data-placeholder-es="Tu nombre" />
        </label>
        <label>
          <span data-en="Phone" data-es="Teléfono">Phone</span>
          <input type="tel" placeholder="Best callback number" data-placeholder-en="Best callback number" data-placeholder-es="Número de contacto" />
        </label>
      </div>
      <label>
        <span data-en="Town / City" data-es="Pueblo / Ciudad">Town / City</span>
        <input type="text" placeholder="Bridgeport, Fairfield, Trumbull…" data-placeholder-en="Bridgeport, Fairfield, Trumbull…" data-placeholder-es="Bridgeport, Fairfield, Trumbull…" />
      </label>
      <label>
        <span data-en="Service Needed" data-es="Servicio Necesario">Service Needed</span>
        <select>
          <option data-en="Deck Building" data-es="Construcción de Deck">Deck Building</option>
          <option data-en="Deck Repair & Restoration" data-es="Reparación de Deck">Deck Repair &amp; Restoration</option>
          <option data-en="Railing Installation" data-es="Instalación de Barandas">Railing Installation</option>
          <option data-en="Exterior Painting" data-es="Pintura Exterior">Exterior Painting</option>
          <option data-en="Interior Painting" data-es="Pintura Interior">Interior Painting</option>
          <option data-en="Home Improvement" data-es="Mejoras del Hogar">Home Improvement</option>
          <option data-en="Other" data-es="Otro">Other</option>
        </select>
      </label>
      <label class="full">
        <span data-en="Project Details" data-es="Detalles del Proyecto">Project Details</span>
        <textarea rows="3"
          placeholder="Describe the project — size, condition, timeline, questions…"
          data-placeholder-en="Describe the project — size, condition, timeline, questions…"
          data-placeholder-es="Describe el proyecto — tamaño, condición, tiempo, preguntas…"></textarea>
      </label>
      <button type="button" data-en="Request My Free Estimate" data-es="Pedir Mi Estimado Gratis">
        Request My Free Estimate
      </button>
    </form>
  </div>
</section>

</main>

<!-- ── FOOTER ── -->
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <div class="footer-logo">
        <span class="footer-i">Irish</span><span class="footer-r"> Home Improvement LLC</span>
      </div>
      <div class="footer-details">
        <span data-en="Licensed Home Improvement Contractor — Bridgeport, CT" data-es="Contratista de Mejoras del Hogar con Licencia — Bridgeport, CT">
          Licensed Home Improvement Contractor — Bridgeport, CT
        </span>
        <span data-en="Mon–Sat 8:30 am – 5:00 pm · Sunday Closed" data-es="Lun–Sáb 8:30 am – 5:00 pm · Domingo Cerrado">
          Mon–Sat 8:30 am – 5:00 pm · Sunday Closed
        </span>
        <address><a href={phone.href}>{phone.display}</a> · {address}</address>
      </div>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      {navLinks.map(([en, es, href]) => (
        <a href={href} data-en={en} data-es={es}>{en}</a>
      ))}
    </nav>
    <p class="footer-copy">
      © {new Date().getFullYear()} Irish Home Improvement LLC.&nbsp;
      <span data-en="All rights reserved." data-es="Todos los derechos reservados.">All rights reserved.</span>
    </p>
  </div>
</footer>

<!-- ── STICKY CTA ── -->
<a class="sticky-call" href={phone.href} aria-label="Call Irish Home Improvement for a free estimate">
  <span data-en="Free Estimate" data-es="Estimado Gratis">Free Estimate</span>
  <strong>{phone.display}</strong>
</a>

<style is:global>
/* ── DESIGN TOKENS ── */
:root {
  --bg:       #f4ede2;
  --bg-2:     #ece4d6;
  --ink:      #0f1c12;
  --ink-2:    #253929;
  --muted:    #607263;
  --brand:    #1b6840;
  --brand-2:  #135230;
  --amber:    #b86e28;
  --amber-lt: #d0863a;
  --amber-dim:#8f5520;
  --border:   rgba(28,104,64,.11);
  --border-dk:rgba(28,104,64,.2);
  --shadow:   0 2px 18px rgba(15,28,18,.07);
  --shadow-h: 0 8px 36px rgba(15,28,18,.14);
  --px:       clamp(1.5rem, 5vw, 5rem);
  --py:       clamp(4rem, 7vw, 7rem);
  --nav-h:    68px;
  --font-d:   'Fraunces', Georgia, serif;
  --font-s:   'DM Sans', system-ui, sans-serif;
  --r:        8px;
}
[data-theme="dark"] {
  --bg:       #0b180d;
  --bg-2:     #111e14;
  --ink:      #e5f0e6;
  --ink-2:    #bdd5be;
  --muted:    #7a987b;
  --border:   rgba(255,255,255,.08);
  --border-dk:rgba(255,255,255,.13);
  --shadow:   0 2px 18px rgba(0,0,0,.28);
  --shadow-h: 0 8px 36px rgba(0,0,0,.48);
}

/* ── RESET ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--font-s);
  font-weight: 400;
  font-size: 1rem;
  line-height: 1.65;
  color: var(--ink);
  background: var(--bg);
  padding-top: var(--nav-h);
  transition: background .3s, color .3s;
}
img { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
address { font-style: normal; }
button { cursor: pointer; font: inherit; }
ul, ol { list-style: none; }

h1, h2, h3 {
  font-family: var(--font-d);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -.015em;
}
h1 em, h2 em {
  font-style: italic;
  font-weight: 300;
  color: var(--amber);
}
[data-theme="dark"] h1 em,
[data-theme="dark"] h2 em { color: var(--amber-lt); }
h2.light { color: #fff; }
h2.light em { color: var(--amber-lt); font-weight: 300; }

.container { max-width: 1200px; margin-inline: auto; padding-inline: var(--px); }
.section     { padding-block: var(--py); }
.section-alt { background: var(--bg-2); }
.section-dark  { background: var(--ink); color: #fff; }
.section-brand { background: var(--brand); color: #fff; }

/* ── EYEBROW ── */
.eyebrow {
  font-family: var(--font-s);
  font-size: .68rem;
  font-weight: 500;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--brand);
  display: flex;
  align-items: center;
  gap: .6rem;
  margin-bottom: 1rem;
}
.eyebrow::before {
  content: '';
  display: inline-block;
  width: 18px; height: 1.5px;
  background: var(--amber);
  flex-shrink: 0;
}
.eyebrow-amber { color: var(--amber-lt); }
.eyebrow-amber::before { background: var(--amber-lt); }
.eyebrow-c { justify-content: center; }
.eyebrow-c::before { display: none; }

.section-head     { max-width: 640px; margin-bottom: clamp(2.5rem,5vw,4rem); }
