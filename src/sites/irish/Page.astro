  const langBtn  = document.querySelector('[data-lang-toggle]') as HTMLButtonElement;
  const themeBtn = document.querySelector('[data-theme-toggle]') as HTMLButtonElement;
  const stored   = { lang: localStorage.getItem('irish-lang') || 'en', theme: localStorage.getItem('irish-theme') || 'light' };

  function applyLang(lang: string) {
    root.lang = lang;
    document.querySelectorAll<HTMLElement>('[data-en][data-es]').forEach(el => {
      const v = el.getAttribute(`data-${lang}`);
      if (v) el.textContent = v;
    });
    document.querySelectorAll<HTMLInputElement>('[data-placeholder-en]').forEach(el => {
      const v = el.getAttribute(`data-placeholder-${lang}`);
      if (v) el.placeholder = v;
    });
    if (langBtn) langBtn.textContent = lang === 'en' ? 'ES' : 'EN';
    localStorage.setItem('irish-lang', lang);
  }

  function applyTheme(t: string) {
    root.dataset.theme = t;
    localStorage.setItem('irish-theme', t);
  }

  applyLang(stored.lang);
  applyTheme(stored.theme);
  langBtn?.addEventListener('click',  () => applyLang(root.lang === 'en' ? 'es' : 'en'));
  themeBtn?.addEventListener('click', () => applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark'));

  const updateNav = () => navEl?.classList.toggle('scrolled', window.scrollY > 40);
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  const obs = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) (e.target as HTMLElement).classList.add('visible'); }),
    { threshold: 0.07, rootMargin: '0px 0px -28px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

</body>
</html>
